# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Remove PrivacyInfo.xcprivacy from source compilation
    # These files should be treated as resources, not source files
    # Only process native targets (not aggregate targets like Firebase)
    if target.is_a?(Xcodeproj::Project::Object::PBXNativeTarget)
      target.source_build_phase.files.each do |file|
        if file.file_ref && file.file_ref.path && file.file_ref.path.end_with?('PrivacyInfo.xcprivacy')
          target.source_build_phase.remove_file_reference(file.file_ref)
        end
      end
    end
    
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      
      # Fix framework search paths for GoogleSignIn and other frameworks
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] ||= ['$(inherited)']
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] << '$(PODS_ROOT)/GoogleSignIn'
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] << '$(PODS_CONFIGURATION_BUILD_DIR)/GoogleSignIn'
      
      # Ensure headers can be found
      config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
      config.build_settings['HEADER_SEARCH_PATHS'] << '$(PODS_ROOT)/GoogleSignIn/GoogleSignIn'
      
      # Fix prefix header paths - ensure they're properly resolved
      if config.build_settings['GCC_PREFIX_HEADER']
        prefix_header = config.build_settings['GCC_PREFIX_HEADER']
        if prefix_header.is_a?(String) && prefix_header.start_with?('Target Support Files/')
          # Convert relative path to use SRCROOT (which points to Pods directory in Pods project)
          config.build_settings['GCC_PREFIX_HEADER'] = "$(SRCROOT)/#{prefix_header}"
        elsif prefix_header.is_a?(String) && prefix_header.include?('$(PODS_ROOT)/Target Support Files/')
          # If already using PODS_ROOT, convert to SRCROOT for Pods project context
          config.build_settings['GCC_PREFIX_HEADER'] = prefix_header.gsub('$(PODS_ROOT)', '$(SRCROOT)')
        end
      end
      
      # Enable module map generation
      config.build_settings['DEFINES_MODULE'] = 'YES'
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
      
      # Enable modules for proper @import support
      config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      
      # Ensure framework search paths include Pods build directory
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] ||= ['$(inherited)']
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] << '$(PODS_CONFIGURATION_BUILD_DIR)'
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] << '$(BUILT_PRODUCTS_DIR)'
    end
  end
  
  # CRITICAL: Update xcconfig files to ensure PODS_ROOT resolves correctly
  # This is important when building from workspace location where SRCROOT might resolve incorrectly
  puts "🔧 Updating xcconfig files to ensure PODS_ROOT resolves correctly..."
  pods_dir = File.expand_path(File.join(File.dirname(__FILE__), 'Pods'))
  xcconfig_files = Dir.glob(File.join(pods_dir, 'Target Support Files', '**', '*.xcconfig'))
  
  xcconfig_files.each do |xcconfig_file|
    content = File.read(xcconfig_file)
    # Check if PODS_ROOT is set and update it to be more robust
    if content.include?('PODS_ROOT = ${SRCROOT}/Pods')
      # Keep the original but add a comment about path resolution
      # The symlinks created by ci_pre_xcodebuild.sh should handle path resolution
      puts "   ✅ Verified PODS_ROOT in #{File.basename(xcconfig_file)}"
    elsif content.include?('PODS_ROOT')
      puts "   ⚠️  PODS_ROOT found in #{File.basename(xcconfig_file)} with different format"
    end
  end
  puts "✅ xcconfig files verified"
  
  # CRITICAL: Set PODS_ROOT in the Runner project's build settings
  # This ensures PODS_ROOT resolves correctly when building from the root workspace
  # The Runner project is at linkUpMobileApp/ios/Runner.xcodeproj
  # Pods are at linkUpMobileApp/ios/Pods, so PODS_ROOT should be ${SRCROOT}/Pods
  runner_project_path = File.expand_path(File.join(File.dirname(__FILE__), 'Runner.xcodeproj'))
  if File.exist?(runner_project_path)
    require 'xcodeproj'
    begin
      runner_project = Xcodeproj::Project.open(runner_project_path)
      pods_dir = File.expand_path(File.join(File.dirname(__FILE__), 'Pods'))
      
      runner_project.targets.each do |target|
        target.build_configurations.each do |config|
          # Set PODS_ROOT relative to the project's SRCROOT (which is the ios directory)
          # This ensures it works whether building from the project directly or from the root workspace
          config.build_settings['PODS_ROOT'] = '${SRCROOT}/Pods'
          
          # CRITICAL: Also set PODS_PODFILE_DIR_PATH to ensure pod scripts can find Podfile
          # This is used by CocoaPods scripts to locate the Podfile
          config.build_settings['PODS_PODFILE_DIR_PATH'] = '${SRCROOT}/.'
          
          # Add user-defined setting for absolute PODS_ROOT as fallback
          # This can be used if SRCROOT resolves incorrectly
          if File.directory?(pods_dir)
            config.build_settings['PODS_ROOT_ABSOLUTE'] = pods_dir
          end
        end
      end
      runner_project.save
      puts "✅ Set PODS_ROOT in Runner project build settings"
    rescue => e
      puts "⚠️  Warning: Could not set PODS_ROOT in Runner project: #{e.message}"
    end
  end
end
